{
  "expo": {
    "name": "Calorie Tracker",
    "slug": "calorie-tracker",
    "scheme": "calorietracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.y3vq3cz.calorietracker"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Calorie Tracker to access your photos for meal analysis.",
          "cameraPermission": "Allow Calorie Tracker to use your camera for meal analysis."
        }
      ],
      "expo-secure-store",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7756166084305700~2592338158",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurementInit": true,
          "userTrackingUsageDescription": "Your device identifier is used to provide relevant ads and improve ad performance."
        }
      ],[
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true,
            "enableBundleCompression": true,
            "extraProguardRules": "-keep class com.google.android.gms.internal.consent_sdk.** { *; }",
            "buildArchs": [
              "arm64-v8a"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef4f2d3c-e858-45f9-8975-91be32927d87"
      }
    }
  }
}
